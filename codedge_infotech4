<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Codedge Infotech – Enterprise AI Infrastructure</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #0A0A0A;
    color: #FFFFFF;
    line-height: 1.5;
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
}

h1 {
    font-size: 72px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
}

.btn-primary {
    display: inline-block;
    background: #FC6B08;
    color: #1A1A1A;
    font-weight: 700;
    padding: 16px 36px;
    border-radius: 8px;
    text-decoration: none;
}

header {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(10, 10, 10, 0.95);
    border-bottom: 1px solid #222;
    padding: 16px 0;
    z-index: 1000;
}

.header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 24px;
    font-weight: 800;
    color: white;
    text-decoration: none;
}

.logo span {
    color: #FC6B08;
}

.nav-links a {
    color: #B0B0B0;
    text-decoration: none;
    margin-left: 32px;
    font-size: 14px;
}

.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 160px 0 100px;
    background: radial-gradient(circle at 20% 30%, #1A1A3A 0%, #0A0A0A 100%);
}

.gradient-text {
    background: linear-gradient(135deg, #FFFFFF 0%, #5254B0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

.hero-stats {
    display: flex;
    gap: 48px;
    margin-top: 60px;
}

.hero-stat .number {
    font-size: 32px;
    font-weight: 800;
    color: #FC6B08;
}

.hero-stat .label {
    font-size: 13px;
    color: #B0B0B0;
}

.section {
    padding: 100px 0;
}

.section-dark {
    background: #050505;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-header h2 {
    font-size: 48px;
    margin-bottom: 20px;
}

.section-header p {
    font-size: 18px;
    color: #B0B0B0;
    max-width: 700px;
    margin: 0 auto;
}

.grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
}

.card {
    background: #111111;
    border-radius: 24px;
    padding: 32px;
    border: 1px solid #222;
    transition: all 0.3s;
}

.card:hover {
    transform: translateY(-6px);
    border-color: #3E4095;
}

.card-icon {
    font-size: 48px;
    margin-bottom: 24px;
}

.card-category {
    font-size: 11px;
    color: #FC6B08;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: inline-block;
}

.card h3 {
    font-size: 24px;
    margin-bottom: 12px;
}

.card p {
    color: #B0B0B0;
    font-size: 14px;
    line-height: 1.6;
}

.metrics-row {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    text-align: center;
}

.metric-number {
    font-size: 56px;
    font-weight: 800;
    color: #FC6B08;
}

.metric-label {
    font-size: 14px;
    color: #B0B0B0;
    margin-top: 12px;
}

.cta-section {
    background: linear-gradient(135deg, #3E4095 0%, #2B2D6B 100%);
    border-radius: 40px;
    padding: 80px 48px;
    text-align: center;
}

footer {
    background: #050505;
    padding: 80px 0 40px;
    border-top: 1px solid #222;
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
}

.footer-col a {
    display: block;
    color: #B0B0B0;
    text-decoration: none;
    margin-bottom: 12px;
    font-size: 13px;
}

.footer-col a:hover {
    color: #FC6B08;
}

.copyright {
    text-align: center;
    padding-top: 48px;
    margin-top: 48px;
    border-top: 1px solid #222;
    font-size: 13px;
    color: #B0B0B0;
}

.parent-badge {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #3E4095;
    color: white;
    padding: 8px 16px;
    border-radius: 40px;
    font-size: 11px;
    text-decoration: none;
    z-index: 1000;
}

@media (max-width: 1024px) {
    h1 { font-size: 48px; }
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
    h1 { font-size: 36px; }
    .grid-3 { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .hero-stats { flex-direction: column; gap: 16px; }
    .metrics-row { flex-direction: column; }
}
</style>
</head>
